# assign [app_id="kitty"] workspace "kitty"
bindsym $super+t exec kitty
bindsym $mod+t exec $run_or_raise 
# bindsym  $mod+m exec  ./run-or-raise.sh

bindsym --no-repeat $mod+v exec pidof code && swaymsg [app_id=^code$] focus || (swaymsg workspace "code" && code)
bindsym --no-repeat $mod+b exec pidof brave && swaymsg [app_id=^brave-browser$] focus || (swaymsg workspace "brave" && brave)
# bindsym $mod+v exec swaymsg workspace "code"; exec swaymsg [app_id=^code$] focus || code

bindsym $super+f exec firefox          
bindsym $super+q kill               

