exec waybar
input "type:keyboard" {
    xkb_options caps:hyper
}
set $super Mod4
set $mod Mod4+Control+Alt
set $run_or_raise ~/.nix/src/home-manager/gui/dotfiles/sway/run-or-raise.sh

