{
  "name": "Vimium C",
  "allBrowserUrls": true,
  "exclusionRules": [],
  "keyLayout": 2,
  "keyMappings": [
    "#!no-check",
    "map d removeTab",
    "map u restoreTab",
    "map Q closeOtherTabs",
    "map K previousTab",
    "map J nextTab",
    "map M addBookmark folder=vimium",
    "map <space>h Vomnibar.activateHistory",
    "map <space>H Vomnibar.activateHistoryInNewTab",
    "map <space>b Vomnibar.activateBookmarks",
    "map <space>B Vomnibar.activateHistoryInNewTab",
    "map <space>t Vomnibar.activateTabs",
    "map <space>o Vomnibar.activateEditUrl",
    "map <space>O Vomnibar.activateEditUrlInNewTab",
    "map gh openUrl brave://history/",
    "map gs openUrl brave://settings/",
    "map gb openUrl brave://bookmarks/",
    "map gv openUrl chrome-extension://hfjbmagddngcpeloejdejnfgbamkjaeg/pages/options.html",
    "map z visitPreviousTab",
    "map pp openCopiedUrlInCurrentTab",
    "map Pp openCopiedUrlInNewTab",
    "map + zoomIn",
    "unmap -",
    "map - zoomOut",
    "map : runKey",
    ""
  ],
  "scrollStepSize": 200,
  "searchEngines": [
    "gg: https://www.google.com/search?q=%s \\",
    "  blank=https://www.google.com/ Google",
    "ddg: https://duckduckgo.com/?q=%s DuckDuckGo",
    "  blank=https://duckduckgo.com/ DuckDuckGo",
    "gh: https://github.com/search?q=$s \\",
    "  blank=https://github.com/ GitHub Repo",
    "vc: chrome-extension://hfjbmagddngcpeloejdejnfgbamkjaeg/pages/options.html"
  ],
  "vimSync": true
}
