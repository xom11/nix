#!/bin/bash

APP_NAME="$1"
FOCUSED_WS=$(aerospace list-workspaces --focused)

osascript -e "
    set AppName to \"$APP_NAME\"
    
    tell application AppName
        if it is frontmost then
            tell application \"System Events\"
                keystroke \"h\" using {command down}
            end tell
        else
            do shell script \"
                open -a '\" & AppName & \"'
                aerospace move-node-to-workspace '$FOCUSED_WS' --focus-follows-window
            \"
        end if
    end tell
"