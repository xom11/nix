#!/usr/bin/env sh

# Battery low threshold (percentage)
THRESHOLD=15

# Time to wait between checks (seconds)
SLEEP_TIME=120

while true; do
    # Get battery status (Discharging, Charging, Full)
    STATUS=$(acpi -b | grep -o 'Discharging\|Charging\|Full')

    # Get battery percentage
    PERCENT=$(acpi -b | grep -o '[0-9]*%' | sed 's/%//')

    # Check if battery is discharging and below the set threshold
    if [[ "$STATUS" == "Discharging" ]] && [[ "$PERCENT" -le "$THRESHOLD" ]]; then
        # Send a critical notification
        # -u critical sets the urgency level
        notify-send -u critical "🔋 LOW BATTERY! ($PERCENT%)" "Please plug in your charger immediately."
    fi

    # Pause before checking again
    sleep $SLEEP_TIME
done