#!/bin/sh

# DPI Scaling Script (Xft.dpi)

# Map desired percentage scale to the actual DPI value
declare -A dpi_map=( [200]=192 [150]=144 [125]=120 [100]=96 )

# --- Execution ---

if [ -z "$1" ]; then
    echo "Usage: $0 <SCALE_PERCENT>"
    echo "Supported: ${!dpi_map[@]}"
    exit 1
fi

target_dpi="${dpi_map[$1]}"

if [ -z "$target_dpi" ]; then
    echo "Error: Scale '$1' not supported. Use: ${!dpi_map[@]}"
    exit 1
fi

# Set Xft.dpi for the current session
echo "Xft.dpi: $target_dpi" | xrdb -merge -
echo "DPI set to $target_dpi ($1 %). Restart wm and applications."