{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://rog:20128/v1",
        "apiKey": "{env:ROUTER_KEY}"
      },
      "models": {
        "combo1": {
          "name": "combo1",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "9router/combo1",
  "permission": "allow",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/combo1"
    }
  }
}
