{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "router-search": {
      "type": "local",
      "command": [
        "router-search-mcp"
      ],
      "enabled": true
    }
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:ROUTER_ENDPOINT}",
        "apiKey": "{env:ROUTER_KEY}"
      }
    }
  },
  "model": "9router/combo1",
  "permission": "allow",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./plugin/router-models.mjs"
  ],
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/combo1"
    }
  }
}
