{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:ROUTER_ENDPOINT}",
        "apiKey": "{env:ROUTER_KEY}"
      },
      "models": {
        "combo1": {
          "name": "combo1",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "combo2": {
          "name": "combo2",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "taoxyz": {
          "name": "taoxyz",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "9router/combo1",
  "permission": "allow",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/combo1"
    }
  }
}
