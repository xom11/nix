curl -fsSL https://install.determinate.systems/nix | sh -s -- install --determinate --no-confirm
. /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh

# Single build — symlinks point to Nix store (read-only) but work correctly.
# Activation hook clones ~/.nix for future edits.
# Rebuild from ~/.nix later to switch symlinks to editable paths.
nix run github:nix-community/home-manager -- switch --impure -b backup --flake "github:xom11/nix/main#server" --refresh
add-visudo && add-authkey && set-zsh
sudo apt update && sudo apt upgrade -y
