(include "defcfg.kbd")
(defvar
  undo M-z
  cut M-x
  copy M-c
  paste M-v
  paste_history M-S-v
  del_word_left A-bspc
  del_word_right A-del
  switch_input_method C-spc
  vol_mute mute
  vol_dn vold
  vol_up volu
  br_dn brdn
  br_up brup
)
(defalias
  tab_alias (multi lmet lctl lsft)
  cap_alias (multi lmet lctl lalt)
)
(include "main.kbd")
